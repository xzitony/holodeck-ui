# Database
DATABASE_URL="file:./dev.db"

# JWT - generate a strong random secret
JWT_SECRET="change-me-to-a-strong-random-secret-at-least-32-chars"

# App
NEXT_PUBLIC_APP_NAME="VCF 9 Holodeck Router"

# Domain for HTTPS (Caddy auto-provisions Let's Encrypt cert)
# Set to your real domain for production, e.g. holodeck.example.com
# Leave as localhost for local development (self-signed cert)
DOMAIN=localhost

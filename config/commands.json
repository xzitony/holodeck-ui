  {
    "name": "List Configurations",
    "slug": "get-holodeck-config",
    "description": "List all available Holodeck deployment configurations on the holorouter",
    "template": "Get-HoloDeckConfig",
    "parameters": [],
    "category": "inventory",
    "requiredRole": "user",
    "sortOrder": 0
  },
  {
    "name": "View Config Details",
    "slug": "get-holodeck-config-detail",
    "description": "View the full JSON configuration for a deployment",
    "template": "Import-HoloDeckConfig -ConfigID '{{configId}}' | Out-Null; $config | ConvertTo-Json -Depth 100",
    "parameters": [
      {
        "name": "configId",
        "label": "Config ID",
        "type": "string",
        "required": true,
        "validation": "^[a-zA-Z0-9._-]+$",
        "placeholder": "Auto-filled from active config"
      }
    ],
    "category": "inventory",
    "requiredRole": "user",
    "sortOrder": 1
  },
  {
    "name": "View Instance Details",
